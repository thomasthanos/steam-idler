{
  "appId": "com.ThomasThanos.SouvlatzidikoUnlocker",
  "productName": "Souvlatzidiko-Unlocker",
  "copyright": "MIT",
  "directories": {
    "output": "release",
    "buildResources": "src/assets"
  },
  "files": [
    "dist/**/*",
    "src/assets/**/*",
    "package.json"
  ],
  "asarUnpack": [
    "**/steam/worker.js",
    "node_modules/steamworks.js/**"
  ],
  "extraMetadata": {
    "main": "dist/main/main/index.js"
  },
  "publish": {
    "provider": "github",
    "owner": "ThomasThanos",
    "repo": "steam-idler",
    "releaseType": "release"
  },
  "executableName": "Souvlatzidiko-Unlocker",
  "extraResources": [
    {
      "from": "src/assets/icons/all_steam_x256.ico",
      "to": "all_steam_x256.ico"
    },
    {
      "from": "src/assets/notify.png",
      "to": "notify.png"
    },
    {
      "from": "src/assets/icons/steam.png",
      "to": "steam.png"
    }
  ],
  "artifactName": "Souvlatzidiko-Unlocker-Setup.${ext}",
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "icon": "src/assets/icons/all_steam_x256.ico",
    "requestedExecutionLevel": "asInvoker"
  },
  "nsis": {
    "oneClick": true,
    "perMachine": false,
    "allowToChangeInstallationDirectory": false,
    "installerIcon": "src/assets/icons/all_steam_x256.ico",
    "uninstallerIcon": "src/assets/icons/all_steam_x256.ico",
    "installerHeaderIcon": "src/assets/icons/all_steam_x256.ico",
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Souvlatzidiko-Unlocker",
    "include": "src/assets/installer.nsh",
    "warningsAsErrors": false
  },
}
